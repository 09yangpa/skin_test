# Keep this server-side only. Never paste this key into browser JavaScript.
OPENAI_API_KEY=sk-your-key-here

# Optional. gpt-4.1-mini is a practical default for local vision/text prototyping.
OPENAI_MODEL=gpt-4.1-mini

# Optional local port.
PORT=3000

# MongoDB target for moving the local product/ingredient SQLite data.
MONGO_URI=mongodb+srv://user:password@cluster.example.mongodb.net
SKIN_MONGO_DB=castshop_gift_test
SKIN_PRODUCTS_COLLECTION=skin_products
